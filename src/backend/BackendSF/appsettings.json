{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=TripPlannerDb;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Cors": {
    "ReactOrigin": "http://localhost:5173"
  },
  "Jwt": {
    "Issuer": "TripPlanner",
    "Audience": "TripPlannerFrontend",
    "Key": "development-key-change-before-running-the-project"
  },
  "ServiceFabric": {
    "ValidatorServiceUri": "fabric:/TripPlannerApplication/ValidatorService",
    "ShareServiceUri": "fabric:/TripPlannerApplication/ShareService",
    "EventDispatcherServiceUri": "fabric:/TripPlannerApplication/EventDispatcherService"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
